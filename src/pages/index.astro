---
/**
 * Home: Header + Hero + Stack + Proyectos + Experiencia
 * (orden de construcción, ver docs/DECISIONS.md). "Sobre mí" vive en su
 * propia ruta `/sobre-mi` — Ver ADR-011.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/features/header/Header.astro';
import Hero from '@/features/hero/Hero.astro';
import StackSection from '@/features/stack/StackSection.astro';
import ProjectsSection from '@/features/projects/ProjectsSection.astro';
import ExperienceSection from '@/features/experience/ExperienceSection.astro';
---

<BaseLayout
  title="Carlos Quiroz — Desarrollador Full Stack"
  description="Portafolio de Carlos Quiroz, desarrollador Full Stack. Diseño e implemento sistemas escalables e interfaces web enfocadas en la experiencia de usuario."
>
  <div id="top">
    <Header />
    <main class="mx-auto max-w-6xl px-4 py-12 md:py-20">
      <Hero />
      <StackSection />
      <ProjectsSection />
      <ExperienceSection />
    </main>
  </div>

  <script>
    import '@/scripts/lang-toggle.ts';
    import '@/scripts/hamburger.ts';
    import '@/features/hero/copy-email.ts';
  </script>
</BaseLayout>
