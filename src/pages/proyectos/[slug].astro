---
/**
 * Detalle de proyecto (ver ADR-006): ruta dinámica, no modal. Una página
 * por entrada de la colección `projects`, generada en build.
 * Sin Header/nav: el back-link de ProjectHeader reemplaza la navegación.
 */
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectDetail from '@/features/projects/ProjectDetail.astro';

export async function getStaticPaths() {
  const proyectos = await getCollection('projects');
  return proyectos.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { titulo, resumen } = entry.data;
---

<BaseLayout title={`${titulo.es} — Carlos Quiroz`} description={resumen.es}>
  <main class="mx-auto max-w-6xl px-4 py-12 md:py-20">
    <ProjectDetail entry={entry} />
  </main>
</BaseLayout>
