---
/**
 * Card de una categoría del stack (Backend, Frontend, etc.).
 * Ver ADR-004: cada entrada de la colección `stack` es una categoría con
 * su array de tecnologías.
 */
import type { CollectionEntry } from 'astro:content';
import Icon from '@/components/ui/Icon.astro';
import T from '@/components/ui/T.astro';

interface Props {
  entry: CollectionEntry<'stack'>;
}

const { entry } = Astro.props;
const { nombre, tecnologias } = entry.data;

// Box del icono anidado en una card `surface` → sube un escalón a
// `surface-2` (bg → surface → surface-2, ver DESIGN.md). Mismo patrón
// que SocialLinks.astro, solo cambia el fondo por el anidado.
const box =
  'grid size-14 place-items-center rounded-xl border border-border bg-surface-2 text-text-secondary transition-colors group-hover:border-accent group-hover:text-accent';
const label = 'font-mono text-xs text-text-muted';
---

<article class="border-border bg-surface rounded-2xl border p-6">
  <T as="h3" t={nombre} class="text-text-primary mb-6 text-lg font-semibold" />
  <ul class="flex flex-wrap gap-5">
    {
      tecnologias.map((tech) => (
        <li>
          <div class="group flex flex-col items-center gap-2">
            <span class={box}>
              <Icon name={tech.icono} size={26} />
            </span>
            <span class={label}>{tech.nombre}</span>
          </div>
        </li>
      ))
    }
  </ul>
</article>
