---
/**
 * Sección "Arquitectura — el porqué": diagrama (ADR-007) arriba y
 * decisiones clave debajo, en una sola columna. Se renderiza solo cuando
 * existe al menos uno de los dos (ver ProjectDetail.astro).
 */
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import T from '@/components/ui/T.astro';

type ProjectData = CollectionEntry<'projects'>['data'];

interface Props {
  slug: string;
  titulo: ProjectData['titulo'];
  diagrama: ProjectData['diagrama'];
  decisionesClave: ProjectData['decisionesClave'];
}

const { slug, titulo, diagrama, decisionesClave } = Astro.props;

const ui = await getEntry('ui', 'projects');
const { arquitecturaTitulo, decisionesClaveTitulo } = ui.data as {
  arquitecturaTitulo: { es: string; en: string };
  decisionesClaveTitulo: { es: string; en: string };
};
---

<section class="border-border mt-10 border-t pt-10 md:mt-12 md:pt-12">
  <T as="h2" t={arquitecturaTitulo} class="text-text-primary mb-6 text-2xl font-semibold" />
  <div class="grid gap-8">
    {
      diagrama && (
        <div>
          {/* Ver ADR-007: dos SVGs generados por `pnpm diagrams`, alternados por breakpoint */}
          <img
            src={`/diagrams/${slug}-desktop.svg`}
            alt={titulo.es}
            class="hidden w-full rounded-xl md:block"
          />
          <img
            src={`/diagrams/${slug}-mobile.svg`}
            alt={titulo.es}
            class="w-full rounded-xl md:hidden"
          />
        </div>
      )
    }
    {
      decisionesClave && (
        <div class="border-border bg-surface rounded-2xl border p-6">
          <T
            as="h3"
            t={decisionesClaveTitulo}
            class="text-text-primary mb-4 text-lg font-semibold"
          />
          <ul class="flex flex-col gap-4">
            {decisionesClave.map((item) => (
              <li>
                <T
                  as="strong"
                  t={item.decision}
                  class="text-text-primary block text-sm font-medium"
                />
                <T as="p" t={item.porQue} class="text-text-secondary mt-1 text-sm" />
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</section>
