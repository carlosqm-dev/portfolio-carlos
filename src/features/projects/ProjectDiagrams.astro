---
/**
 * Sección "Diagramas": una pila vertical de N diagramas con subtítulo
 * bilingüe, seguidos de las decisiones clave. Se renderiza solo cuando
 * existe al menos uno de los dos (ver ProjectDetail.astro).
 *
 * Ver ADR-007: por cada entrada de `diagrams` se generan dos SVGs
 * (`{slug}-desktop-{N}.svg` y `{slug}-mobile-{N}.svg`) con `pnpm diagrams`.
 */
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import T from '@/components/ui/T.astro';

type ProjectData = CollectionEntry<'projects'>['data'];

interface Props {
  slug: string;
  title: ProjectData['title'];
  diagrams: NonNullable<ProjectData['diagrams']>;
  keyDecisions: ProjectData['keyDecisions'];
}

const { slug, title, diagrams, keyDecisions } = Astro.props;

const ui = await getEntry('ui', 'projects');
const { architectureTitle, keyDecisionsTitle } = ui.data as {
  architectureTitle: { es: string; en: string };
  keyDecisionsTitle: { es: string; en: string };
};
---

<section class="border-border mt-10 border-t pt-10 md:mt-12 md:pt-12">
  <T as="h2" t={architectureTitle} class="text-text-primary mb-6 text-2xl font-semibold" />
  <div class="flex flex-col gap-10">
    {
      diagrams.map((d, i) => (
        <figure class="flex flex-col gap-3">
          <T as="figcaption" t={d.title} class="text-text-primary text-sm font-semibold" />
          {/* Ver ADR-007: dos SVGs por diagrama, alternados por breakpoint */}
          <img
            src={`/diagrams/${slug}-desktop-${i}.svg`}
            alt={title.es}
            class="hidden w-full rounded-xl md:block"
          />
          <img
            src={`/diagrams/${slug}-mobile-${i}.svg`}
            alt={title.es}
            class="w-full rounded-xl md:hidden"
          />
        </figure>
      ))
    }
    {
      keyDecisions && (
        <div class="border-border bg-surface rounded-2xl border p-6">
          <T as="h3" t={keyDecisionsTitle} class="text-text-primary mb-4 text-lg font-semibold" />
          <ul class="flex flex-col gap-4">
            {keyDecisions.map((item) => (
              <li>
                <T
                  as="strong"
                  t={item.decision}
                  class="text-text-primary block text-sm font-medium"
                />
                <T as="p" t={item.why} class="text-text-secondary mt-1 text-sm" />
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</section>
