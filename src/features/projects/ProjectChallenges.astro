---
/**
 * Bloque opcional "Desafíos y soluciones" del detalle de proyecto.
 */
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import T from '@/components/ui/T.astro';

interface Props {
  desafios: NonNullable<CollectionEntry<'projects'>['data']['desafios']>;
}

const { desafios } = Astro.props;

const ui = await getEntry('ui', 'projects');
const { desafiosTitulo } = ui.data as { desafiosTitulo: { es: string; en: string } };
---

<section class="border-border mt-10 border-t pt-10 md:mt-12 md:pt-12">
  <T as="h2" t={desafiosTitulo} class="text-text-primary mb-6 text-2xl font-semibold" />
  <div class="grid gap-6 md:grid-cols-2">
    {
      desafios.map((item) => (
        <div class="border-border bg-surface rounded-2xl border p-6">
          <T as="h3" t={item.titulo} class="text-text-primary mb-2 text-base font-semibold" />
          <T as="p" t={item.solucion} class="text-text-secondary text-sm" />
        </div>
      ))
    }
  </div>
</section>
