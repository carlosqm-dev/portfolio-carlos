---
/**
 * Layout del detalle de proyecto (ver ADR-006). Orquesta las sub-partes
 * de la feature; cada bloque opcional se renderiza solo si el dato
 * existe en la colección.
 */
import type { CollectionEntry } from 'astro:content';
import T from '@/components/ui/T.astro';
import ProjectHeader from './ProjectHeader.astro';
import ProjectLinks from './ProjectLinks.astro';
import ProjectStack from './ProjectStack.astro';
import ProjectArchitecture from './ProjectArchitecture.astro';
import ProjectChallenges from './ProjectChallenges.astro';
import ImageLightbox from './ImageLightbox.astro';

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { titulo, imagen, galeria, descripcion, stack, diagrama, decisionesClave, desafios, links } =
  entry.data;
---

<article>
  <ProjectHeader entry={entry} />

  <section class="mt-10 grid gap-8 md:mt-12 md:grid-cols-2">
    <div class="flex flex-col gap-4">
      <button
        type="button"
        data-lightbox-trigger
        data-src={imagen.src}
        data-alt={imagen.alt.es}
        class="block w-full cursor-zoom-in"
      >
        <img
          src={imagen.src}
          alt={imagen.alt.es}
          class="aspect-video w-full rounded-2xl object-cover"
        />
      </button>
      {
        galeria && (
          <div class="grid grid-cols-2 gap-4">
            {galeria.map((foto) => (
              <button
                type="button"
                data-lightbox-trigger
                data-src={foto.src}
                data-alt={foto.alt.es}
                class="block w-full cursor-zoom-in"
              >
                <img
                  src={foto.src}
                  alt={foto.alt.es}
                  class="aspect-video w-full rounded-xl object-cover"
                />
              </button>
            ))}
          </div>
        )
      }
    </div>
    <T
      as="p"
      t={descripcion}
      class="text-text-secondary text-base leading-relaxed whitespace-pre-line"
    />
  </section>

  <ProjectStack stackIds={stack} />

  {
    (diagrama || decisionesClave) && (
      <ProjectArchitecture
        slug={entry.id}
        titulo={titulo}
        diagrama={diagrama}
        decisionesClave={decisionesClave}
      />
    )
  }

  {desafios && <ProjectChallenges desafios={desafios} />}

  <footer class="border-border mt-10 flex justify-end border-t pt-10 md:mt-12 md:pt-12">
    <ProjectLinks links={links} />
  </footer>

  <ImageLightbox />
</article>
