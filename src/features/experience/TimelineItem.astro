---
/**
 * Una entrada de la timeline (laboral o profesional). Ver ADR-010.
 * El riel continuo vive en el <ol> de TimelineColumn; acá solo se dibuja
 * el punto (dot), espejado a la derecha cuando side="right" (solo md+,
 * en mobile ambas columnas apilan con el riel a la izquierda).
 */
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import T from '@/components/ui/T.astro';

interface Props {
  entry: CollectionEntry<'experience'>;
  side: 'left' | 'right';
}

const { entry, side } = Astro.props;
const { role, company, location, startDate, endDate, achievements } = entry.data;
const isRight = side === 'right';
const isCurrent = endDate === null;

const ui = await getEntry('ui', 'experience');
const { present, months } = ui.data as {
  present: { es: string; en: string };
  months: Record<string, { es: string; en: string }>;
};

const [yearStart, monthStart] = startDate.split('-');
const start = {
  es: `${months[monthStart].es} ${yearStart}`,
  en: `${months[monthStart].en} ${yearStart}`,
};

let end: { es: string; en: string };
if (isCurrent) {
  end = present;
} else {
  const [yearEnd, monthEnd] = endDate.split('-');
  end = { es: `${months[monthEnd].es} ${yearEnd}`, en: `${months[monthEnd].en} ${yearEnd}` };
}

const range = { es: `${start.es} — ${end.es}`, en: `${start.en} — ${end.en}` };

// El dot se centra sobre la línea del <ol> (border-l/r): `left-0`/`right-0`
// coincide con el borde de la línea, y el translate lo corre la mitad de su
// propio tamaño para quedar centrado encima.
const liClass = isRight ? 'relative pl-6 md:pl-0 md:pr-6' : 'relative pl-6';
const dotClass = isRight
  ? 'bg-accent absolute left-0 top-1 size-2.5 -translate-x-1/2 rounded-full md:left-auto md:right-0 md:translate-x-1/2'
  : 'bg-accent absolute left-0 top-1 size-2.5 -translate-x-1/2 rounded-full';
---

<li class={liClass}>
  <span class={dotClass} aria-hidden="true"></span>
  <T t={range} class="text-text-muted font-mono text-xs" />
  <p class="mt-1">
    <T as="span" t={role} class="text-text-primary font-medium" />
    <span class="text-text-secondary"> — {company}</span>
    {location && <span class="text-text-muted"> · {location}</span>}
  </p>
  {
    achievements && achievements.length > 0 && (
      <ul class="marker:text-text-muted mt-3 flex list-disc flex-col gap-1.5 pl-4">
        {achievements.map((achievement) => (
          <li>
            <T as="span" t={achievement} class="text-text-secondary text-sm" />
          </li>
        ))}
      </ul>
    )
  }
</li>
