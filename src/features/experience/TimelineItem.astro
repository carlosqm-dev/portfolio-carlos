---
/**
 * Una entrada de la timeline (laboral o profesional). Ver ADR-010.
 * El riel continuo vive en el <ol> de TimelineColumn; acá solo se dibuja
 * el punto (dot), espejado a la derecha cuando side="right" (solo md+,
 * en mobile ambas columnas apilan con el riel a la izquierda).
 */
import { getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import T from '@/components/ui/T.astro';

interface Props {
  entry: CollectionEntry<'experience'>;
  side: 'left' | 'right';
}

const { entry, side } = Astro.props;
const { rol, empresa, lugar, fechaInicio, fechaFin, logros } = entry.data;
const isRight = side === 'right';
const esActual = fechaFin === null;

const ui = await getEntry('ui', 'experience');
const { presente, meses } = ui.data as {
  presente: { es: string; en: string };
  meses: Record<string, { es: string; en: string }>;
};

const [anioInicio, mesInicio] = fechaInicio.split('-');
const inicio = {
  es: `${meses[mesInicio].es} ${anioInicio}`,
  en: `${meses[mesInicio].en} ${anioInicio}`,
};

let fin: { es: string; en: string };
if (esActual) {
  fin = presente;
} else {
  const [anioFin, mesFin] = fechaFin.split('-');
  fin = { es: `${meses[mesFin].es} ${anioFin}`, en: `${meses[mesFin].en} ${anioFin}` };
}

const rango = { es: `${inicio.es} — ${fin.es}`, en: `${inicio.en} — ${fin.en}` };

// El dot se centra sobre la línea del <ol> (border-l/r): `left-0`/`right-0`
// coincide con el borde de la línea, y el translate lo corre la mitad de su
// propio tamaño para quedar centrado encima.
const liClass = isRight ? 'relative pl-6 md:pl-0 md:pr-6' : 'relative pl-6';
const dotClass = isRight
  ? 'bg-accent absolute left-0 top-1 size-2.5 -translate-x-1/2 rounded-full md:left-auto md:right-0 md:translate-x-1/2'
  : 'bg-accent absolute left-0 top-1 size-2.5 -translate-x-1/2 rounded-full';
---

<li class={liClass}>
  <span class={dotClass} aria-hidden="true"></span>
  <T t={rango} class="text-text-muted font-mono text-xs" />
  <p class="mt-1">
    <T as="span" t={rol} class="text-text-primary font-medium" />
    <span class="text-text-secondary"> — {empresa}</span>
    {lugar && <span class="text-text-muted"> · {lugar}</span>}
  </p>
  {
    logros && logros.length > 0 && (
      <ul class="marker:text-text-muted mt-3 flex list-disc flex-col gap-1.5 pl-4">
        {logros.map((logro) => (
          <li>
            <T as="span" t={logro} class="text-text-secondary text-sm" />
          </li>
        ))}
      </ul>
    )
  }
</li>
