---
/**
 * Sección Experiencia — paso 6 del orden de construcción
 * (ver docs/DECISIONS.md). Ver ADR-010: dos timelines paralelas
 * (Laboral | Profesional) separadas por una línea divisora vertical.
 */
import { getCollection, getEntry } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import T from '@/components/ui/T.astro';
import TimelineColumn from './TimelineColumn.astro';

const ui = await getEntry('ui', 'experience');
const { title, laboral, profesional } = ui.data as {
  title: { es: string; en: string };
  laboral: { es: string; en: string };
  profesional: { es: string; en: string };
};

const entries = await getCollection('experience');

// Más reciente primero — se ordena acá, nunca se confía en el orden del
// archivo (ver ADR-010). `orden` desempata cuando dos entradas comparten mes.
function porFechaDesc(a: CollectionEntry<'experience'>, b: CollectionEntry<'experience'>) {
  if (a.data.fechaInicio !== b.data.fechaInicio) {
    return a.data.fechaInicio > b.data.fechaInicio ? -1 : 1;
  }
  return a.data.orden - b.data.orden;
}

const laboralEntries = entries.filter((e) => e.data.tipo === 'laboral').sort(porFechaDesc);
const profesionalEntries = entries.filter((e) => e.data.tipo === 'profesional').sort(porFechaDesc);
---

<section id="experiencia" class="mt-24 scroll-mt-24 md:mt-32">
  <T as="h2" t={title} class="text-text-primary mb-8 text-3xl font-semibold" />
  <div class="md:divide-border grid gap-10 md:grid-cols-2 md:gap-0 md:divide-x">
    <TimelineColumn label={laboral} entries={laboralEntries} side="left" />
    <TimelineColumn label={profesional} entries={profesionalEntries} side="right" />
  </div>
</section>
