---
/**
 * Sección Sobre mí — último paso del orden de construcción.
 * Ver ADR-010: dos columnas — descripción personal a la izquierda,
 * carrusel de fotos a la derecha.
 */
import { getEntry } from 'astro:content';
import T from '@/components/ui/T.astro';
import PhotoCarousel from './PhotoCarousel.astro';

const ui = await getEntry('ui', 'about');
const { title } = ui.data as {
  title: { es: string; en: string };
};

const about = await getEntry('about', 'about');
const { descripcion, hobbies, fotos } = about.data;
---

<section id="sobre-mi" class="mt-24 scroll-mt-24 md:mt-32">
  <T as="h2" t={title} class="text-text-primary mb-8 text-3xl font-semibold" />
  <div class="grid items-center gap-12 md:grid-cols-2">
    <div>
      <T as="p" t={descripcion} class="text-text-secondary leading-relaxed" />
      {
        hobbies && (
          <ul class="mt-6 flex flex-wrap gap-2">
            {hobbies.map((hobby) => (
              <li class="border-border text-text-muted rounded-full border px-3 py-1 font-mono text-xs">
                <T t={hobby} />
              </li>
            ))}
          </ul>
        )
      }
    </div>
    <PhotoCarousel fotos={fotos} />
  </div>
</section>
