---
/**
 * Toggle de idioma con indicador deslizante (segmented control).
 * Ver ADR-003: el sistema bilingüe (data-lang en <html>, localStorage,
 * script anti-flash en BaseLayout) no se toca — este componente solo
 * cambia la presentación del control.
 *
 * Responsabilidades:
 *  - Renderizar dos botones con aria-pressed, uno por idioma.
 *  - Mostrar un indicador que se desliza al activo vía CSS leyendo
 *    html[data-lang] (sin JS para la animación).
 *  - Sincronizar aria-pressed en runtime vía src/scripts/lang-toggle.ts.
 *
 * Importante: los botones usan `data-lang-option` (NO `data-lang`).
 * El atributo `data-lang` está reservado por el sistema bilingüe (ADR-003)
 * para spans de contenido traducible, y el selector global lo oculta
 * según html[data-lang]. Reutilizarlo acá rompería el toggle.
 *
 * Colores del slot activo: fondo accent + texto on-accent (patrón "botón
 * primario" del design system). Los colores los aplica CSS leyendo
 * html[data-lang], ver global.css.
 */

interface Props {
  /** Labels de los dos botones. Cada label se renderiza en su propio idioma. */
  labels: { es: string; en: string };
  /** Clases extra del contenedor (ej: "w-full" en mobile). */
  class?: string;
}

const { labels, class: extraClass = '' } = Astro.props;
---

<div
  role="group"
  aria-label="Idioma"
  data-lang-toggle-root
  class:list={[
    'lang-toggle border-border bg-surface/80 relative inline-flex items-center rounded-2xl border p-1',
    extraClass,
  ]}
>
  {
    /* Indicador deslizante — único span, animado por CSS leyendo html[data-lang].
      Ver docs/plans/2026-07-03-lang-toggle-slider-design.md.
      En estado activo: fondo accent + texto on-accent (patrón "botón primario"
      del design system, aplicado al slot activo del toggle). */
  }
  <span
    aria-hidden="true"
    class="lang-toggle__indicator bg-surface-2 pointer-events-none absolute top-1 bottom-1 left-1 w-[calc(50%-0.25rem)] rounded-xl border border-transparent transition-[transform,background-color,border-color] duration-200 ease-out"
  ></span>

  <button
    type="button"
    data-lang-option="es"
    aria-pressed="true"
    class="lang-toggle__btn text-text-primary relative z-10 flex-1 px-3 py-1 text-center font-mono text-sm transition-colors"
  >
    {labels.es}
  </button>
  <button
    type="button"
    data-lang-option="en"
    aria-pressed="false"
    class="lang-toggle__btn text-text-muted hover:text-text-secondary relative z-10 flex-1 px-3 py-1 text-center font-mono text-sm transition-colors"
  >
    {labels.en}
  </button>
</div>
